{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext", "webworker"],
    "jsx": "react-jsx",
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "allowJs": true,
    "checkJs": true
  },
  "include": [
    ".astro/types.d.ts",
    ".eslintrc.cjs",
    "src/astro-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.astro",
    "**/*.cjs",
    "**/*.mjs"
  ],
  "exclude": ["node_modules", "dist"]
}
