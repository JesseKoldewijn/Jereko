---
import NavbarMenu from "@/components/layout/navbar/navigationMenu";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";

// socials prop kept for API compatibility (used by Layout.astro); not needed here
// after NavbarMenu was moved to a standalone island
interface Props {
  socials?: unknown;
}
---

<!--
  Static <nav> shell — painted immediately, before any JS hydration.
  Logo + mobile toggle + ThemeToggle are plain Astro HTML (zero hydration cost).
  NavbarMenu (Radix) is a client:visible island that hydrates on intersection.
  astro-island has display:contents so its children are direct flex items of <nav>.
-->
<nav
  id="navbar"
  transition:persist="shell-navbar"
  class="max-w-auto sticky top-0 z-50 flex w-full px-6 py-4 transition-colors! duration-200! ease-in-out! bg-[rgba(255,255,255,0.85)] dark:bg-[rgba(18,18,18,0.80)]"
>
  <!-- Logo: static HTML, zero hydration cost -->
  <section class="my-auto mr-auto">
    <a
      href="/"
      id="Jereko logo"
      class="flex font-semibold duration-500 hover:underline hover:underline-offset-4"
    >
      Jereko
    </a>
  </section>

  <!-- Desktop nav (Radix NavigationMenu): hydrates when scrolled into view -->
  <section class="my-auto flex flex-1 justify-center">
    <NavbarMenu client:visible />
  </section>

  <!-- Right section: mobile toggle (static) + theme toggle (static) -->
  <section class="my-auto mr-0 ml-auto flex gap-4">
    <!--
      Mobile menu toggle — opens the native <dialog> via showModal().
      Purely a DOM call; no React context needed.
      Icon swap handled in globals.css via :has([open]) on the dialog.
    -->
    <button
      class="ring-offset-background focus-visible:ring-ring bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-10 items-center justify-center rounded-lg border p-2 px-4 py-2 text-sm font-medium whitespace-nowrap transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none md:hidden"
      data-mobile-menu-toggle
      aria-label="Toggle mobile navigation menu"
      aria-controls="mobile-nav-dialog"
    >
      <!-- Menu icon (shown when dialog is closed) -->
      <svg
        class="mobile-nav-icon-menu h-5 w-5"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
      <!-- Close icon (shown when dialog is open) -->
      <svg
        class="mobile-nav-icon-close h-5 w-5"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
      <span class="sr-only">Toggle mobile navigation menu</span>
    </button>

    <ThemeToggle />
  </section>
</nav>

<script>
  function setupMobileToggle() {
    const btn = document.querySelector<HTMLButtonElement>(
      "[data-mobile-menu-toggle]",
    );
    if (!btn) return;
    btn.addEventListener("click", () => {
      const dialog =
        document.querySelector<HTMLDialogElement>("#mobile-nav-dialog");
      if (dialog?.open) dialog.close();
      else dialog?.showModal();
    });
  }

  setupMobileToggle();
  document.addEventListener("astro:after-swap", setupMobileToggle);
</script>
