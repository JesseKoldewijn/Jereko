---
import { appConfig } from "@/config/app";
import { listedLinks, showcaseLinks } from "@/data/navigation";
import type { Socials } from "@/data/socials";

interface Props {
  socials: Socials | null;
}

const { socials } = Astro.props;

// Inline SVG path data for all icons used in the mobile menu
// Base SVG attrs for stroke icons: viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
const icons = {
  home: `<path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>`,
  projects: `<path d="M3 12h.01"/><path d="M3 18h.01"/><path d="M3 6h.01"/><path d="M8 12h13"/><path d="M8 18h13"/><path d="M8 6h13"/>`,
  experience: `<path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/>`,
  root: `<path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>`,
  hobbies: `<rect width="14" height="8" x="5" y="2" rx="2"/><rect width="20" height="8" x="2" y="14" rx="2"/><path d="M6 18h2"/><path d="M12 18h6"/>`,
  volunteering: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"/><path d="m18 15-2-2"/><path d="m15 18-2-2"/>`,
  github: `<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>`,
  linkedin: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>`,
};

// Twitter X icon — different viewBox and fill-based (not stroke)
const twitterXPath = `<path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/>`;

const linkClass =
  "border-foreground flex w-full items-center justify-center gap-2 rounded-lg border p-2";
---

<!--
  Frosted glass backdrop lives OUTSIDE the <dialog> as a persistent sibling.
  Being always present in the DOM lets the browser pre-warm the GPU compositing
  layer for backdrop-filter, eliminating the blur "pop-in" lag on open.
  Visibility is toggled by :has(#mobile-nav-dialog[open]) in globals.css.
-->
<div id="mobile-nav-backdrop" aria-hidden="true"></div>

<dialog id="mobile-nav-dialog">
  <!-- Scrollable content — this div is what fades/slides in -->
  <div
    id="mobile-nav-content"
    class="text-foreground flex max-h-[calc(100dvh-4.5rem)] w-full flex-col items-center gap-4 overflow-y-auto px-4 pt-4 pb-8"
  >
    <strong>General Pages</strong>

    {
      listedLinks.links.map((entry) => {
        const segment = entry.href.split("/")[1];
        const key = (
          segment !== "" && segment != null ? segment : "home"
        ) as keyof typeof icons;
        const iconPaths = icons[key] ?? icons.projects;
        return (
          <a href={entry.href} class={linkClass}>
            <svg
              set:html={iconPaths}
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            />
            {entry.title}
          </a>
        );
      })
    }

    <a
      href={appConfig.repo.href}
      target="_blank"
      rel="noopener noreferrer"
      class={linkClass}
    >
      <svg
        set:html={icons.github}
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      />
      OpenSource
    </a>

    <strong>About Me</strong>

    {
      showcaseLinks.links.map((entry) => {
        const parts = entry.href.split("/");
        const segment = parts[2];
        const key = (
          segment !== "" && segment != null ? segment : "root"
        ) as keyof typeof icons;
        const iconPaths = icons[key] ?? icons.root;
        return (
          <a href={entry.href} class={linkClass}>
            <svg
              set:html={iconPaths}
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            />
            {entry.title}
          </a>
        );
      })
    }

    {
      socials && (
        <>
          <strong>Socials</strong>
          {socials.map((social) => {
            const href = social.link ?? "#";
            const isTwitter = social.platform === "twitter";
            const iconPaths =
              icons[social.platform as keyof typeof icons] ?? icons.github;
            return (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class={linkClass}
              >
                {isTwitter ? (
                  <svg
                    set:html={twitterXPath}
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="currentColor"
                    aria-hidden="true"
                  />
                ) : (
                  <svg
                    set:html={iconPaths}
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  />
                )}
                {social.label}
              </a>
            );
          })}
        </>
      )
    }
  </div>
</dialog>

<script>
  function setupMobileNavDialog() {
    const dialog =
      document.querySelector<HTMLDialogElement>("#mobile-nav-dialog");
    const closeBtn = document.querySelector<HTMLButtonElement>(
      "#mobile-nav-dialog-close",
    );

    // Explicit close button inside the dialog (needed because showModal() traps focus)
    closeBtn?.addEventListener("click", () => dialog?.close());

    // Clicking the ::backdrop area fires a click on the dialog element itself
    // (e.target === dialog). Use this to close when tapping outside the content.
    dialog?.addEventListener("click", (e) => {
      if (e.target === dialog) dialog?.close();
    });
  }

  setupMobileNavDialog();
  document.addEventListener("astro:after-swap", setupMobileNavDialog);
</script>
