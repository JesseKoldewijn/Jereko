---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Offline - Jereko"
  description="Offline status page for Jereko. Reconnect to the internet and refresh to continue browsing the site."
>
  <div
    transition:name="simple-page"
    transition:animate="fade"
    class="flex min-h-[60vh] flex-col items-center justify-center gap-4 px-4 text-center"
  >
    <h1 class="text-2xl font-bold md:text-3xl">You're offline</h1>
    <p class="text-muted-foreground max-w-md">
      Check your connection and try again. When you're back online, refresh the
      page.
    </p>
    <button
      type="button"
      class="rounded-lg bg-primary px-4 py-2 text-primary-foreground hover:opacity-90"
      onclick="window.location.reload()"
    >
      Retry
    </button>
    <a
      href="/"
      class="text-muted-foreground underline underline-offset-4 hover:text-foreground"
    >
      Back to home
    </a>
  </div>
</Layout>
