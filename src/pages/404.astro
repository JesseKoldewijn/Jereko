---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="404 | Jereko"
  description="The page you are looking for could not be found on Jereko."
>
  <section
    transition:name="simple-page"
    transition:animate="fade"
    class="mx-auto flex flex-col items-center justify-center gap-8 px-4 py-20 text-center"
  >
    <h1 class="text-4xl font-bold">404</h1>
    <p class="text-neutral-600 dark:text-neutral-200">Page not found.</p>
    <a href="/" class="text-primary underline hover:no-underline">Go home</a>
  </section>
</Layout>
