---
import Layout from "@/layouts/Layout.astro";
import AboutMeHeader from "@/components/page-elements/about-me/AboutMeHeaderAstro";
import AnimatedGradientText from "@/components/animated/animated-grad-text";
import avatarUrl from "@/images/avatar.webp";

const date = new Date(2021, 6, 1);

const volunteeringSince = () => {
  const dateArray = date
    .toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
    .replace(",", "")
    .split(" ");
  return `${dateArray[0]} ${
    dateArray[1] === "1" ? "1st" : `${dateArray[1]}th`
  } ${dateArray[2]}`;
};

const volunteeringForMonths = () => {
  const today = new Date();
  const months = (today.getFullYear() - date.getFullYear()) * 12;
  const difference = today.getMonth() - date.getMonth() + months;
  if (difference > 12) {
    return `${Math.floor(difference / 12)} years and ${difference % 12} months`;
  }
  return String(difference);
};

const bannerImg =
  typeof avatarUrl === "string"
    ? { src: avatarUrl, width: 400, height: 400 }
    : { src: (avatarUrl as { src: string }).src, width: 400, height: 400 };
---

<Layout title="Volunteering | Jereko" description="A page about my volunteering experience.">
  <div transition:name="hero" transition:animate="fade">
    <AboutMeHeader
      client:load
      pathname="/about-me/volunteering"
      bannerImage={{ dark: bannerImg, light: bannerImg }}
      title="Volunteering"
      description="About my volunteering experience. So what do I do?"
    />
  </div>
  <div
    transition:name="about-body"
    transition:animate="fade"
    class="mx-4 flex flex-col items-center justify-center gap-8 lg:mx-2 lg:flex-row"
  >
    <section
      id="about-me-overview"
      class="flex w-auto max-w-md flex-col gap-4 text-center"
    >
      <h2 class="text-center text-2xl font-bold">In what way do I volunteer?</h2>
      <div class="flex flex-col gap-4">
        <p>
          Since {volunteeringSince()} I have been a volunteer for
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="Stack Up"
            noSplit
          />
          as a
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="GameLead"
            noSplit
          />
          . I am responsible for hosting and moderating the
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="Game Nights"
            noSplit
          />
          that I host which I've been hosting once a week (most of the time) for
          the past {volunteeringForMonths()}.
        </p>
        <p>
          What are Game Nights?{" "}
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="Game Nights"
            noSplit
          />
          are a way for Stack Up to bring people together from all over the
          world to play video games and socialize with one another. We host Game
          Nights for a wide variety of games, from
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="Call of Duty"
            noSplit
          />
          to
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="Dungeons & Dragons"
            noSplit
          />
          .
        </p>
        <p>
          The main purpose of Game Nights is to bring people together to have
          fun, make new friends, and to help combat isolation and loneliness by
          providing a
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="safe and welcoming"
            noSplit
          />
          environment everybody is welcome.
        </p>
      </div>
    </section>
    <section
      id="about-me-overview"
      class="flex w-auto max-w-md flex-col gap-4 text-center xs:mb-auto"
    >
      <h2 class="text-center text-2xl font-bold">About Stack Up</h2>
      <div class="flex flex-col gap-4">
        <p>
          <AnimatedGradientText
            client:load
            className="font-semibold"
            variant="span"
            text="Stack Up"
            noSplit
          />
          , a 501(c)(3) non-profit that supports Active, Veteran service members
          and civilians from the U.S. and allied nations by promoting positive
          mental health and combat (mainly veteran) suicide through
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="gaming and geek culture"
            noSplit
          />
          .
        </p>
        <p>
          The main focus of Stack Up is directed towards
          <AnimatedGradientText
            client:load
            className="mx-1 font-semibold"
            variant="span"
            text="Veterans"
            noSplit
          />
          and Active service members, but just about anybody is welcome to join
          the community as long as their over 18 years old.
        </p>
      </div>
    </section>
  </div>
</Layout>
