---
import "@/styles/globals.css";
import PwaRegister from "@/components/PwaRegister";
import AppWrapper from "@/components/layout/AppWrapper";
import FooterWithSlots from "@/components/layout/FooterWithSlots";
import { getSocialsByPlatform } from "@/data/queries";
import { ClientRouter } from "astro:transitions";
import { pwaInfo } from "virtual:pwa-info";

const socials = getSocialsByPlatform("twitter", "github", "linkedin");

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jereko - My personal website | Jesse Koldewijn",
  description = "Personal website of Jesse Koldewijn showcasing projects, experience, volunteering work, and events attended.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/favicons/android-chrome-512x512.png", Astro.site);
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000" />
    <link
      rel="shortcut icon"
      href="/favicons/favicon.ico"
      type="image/x-icon"
    />
    <link rel="preload" href="/fonts/geist-sans/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/geist-mono/GeistMono-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <ClientRouter />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <script is:inline>
      (function () {
        function applyStoredTheme() {
          const theme = localStorage.getItem("theme");
          const systemDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          const resolved =
            theme === "system" || !theme
              ? systemDark
                ? "dark"
                : "light"
              : theme;
          const root = document.documentElement;
          root.classList.remove("light", "dark");
          root.classList.add(resolved);
        }
        applyStoredTheme();
        document.addEventListener("astro:after-swap", applyStoredTheme);
        document.addEventListener("astro:page-load", applyStoredTheme);
      })();
    </script>
  </head>
  <body class="font-sans min-h-screen">
    <PwaRegister client:idle />
    <AppWrapper
      socials={socials}
      client:load
      transition:persist="shell-navbar"
    />
    <main
      class="min-h-[90svh] pb-8"
      transition:name="main"
      transition:animate="fade"
    >
      <slot />
    </main>
    <FooterWithSlots
      client:visible
      socials={socials}
      transition:persist="shell-footer"
    />
  </body>
</html>
